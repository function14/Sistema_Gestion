generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  rol       String   @default("cajero") // admin, cajero, almacen
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  ventas    Venta[]
  compras   Compra[]
}

model Categoria {
  id        Int        @id @default(autoincrement())
  nombre    String     @unique
  productos Producto[]
}

model Producto {
  id            Int                    @id @default(autoincrement())
  nombre        String
  sku           String                 @unique
  precioCompra  Float
  precioVenta   Float
  categoriaId   Int
  stockActual   Int                    @default(0)
  stockMinimo   Int                    @default(5)
  imagen        String?
  activo        Boolean                @default(true)
  createdAt     DateTime               @default(now())
  categoria     Categoria              @relation(fields: [categoriaId], references: [id])
  detallesVenta DetalleVenta[]
  detallesCompra DetalleCompra[]
  movimientos   MovimientoInventario[]
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String?
  telefono  String?
  direccion String?
  rfc       String?
  createdAt DateTime @default(now())
  ventas    Venta[]
}

model Proveedor {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String?
  telefono  String?
  direccion String?
  rfc       String?
  createdAt DateTime @default(now())
  compras   Compra[]
}

model Venta {
  id         Int            @id @default(autoincrement())
  fecha      DateTime       @default(now())
  clienteId  Int?
  usuarioId  Int
  total      Float
  metodoPago String         // efectivo, tarjeta, transferencia
  estado     String         @default("completada") // completada, anulada
  cliente    Cliente?       @relation(fields: [clienteId], references: [id])
  usuario    Usuario        @relation(fields: [usuarioId], references: [id])
  detalles   DetalleVenta[]
}

model DetalleVenta {
  id             Int      @id @default(autoincrement())
  ventaId        Int
  productoId     Int
  cantidad       Int
  precioUnitario Float
  subtotal       Float
  venta          Venta    @relation(fields: [ventaId], references: [id])
  producto       Producto @relation(fields: [productoId], references: [id])
}

model Compra {
  id           Int             @id @default(autoincrement())
  fecha        DateTime        @default(now())
  proveedorId  Int
  usuarioId    Int
  total        Float
  estado       String          @default("pendiente") // pendiente, recibida, cancelada
  proveedor    Proveedor       @relation(fields: [proveedorId], references: [id])
  usuario      Usuario         @relation(fields: [usuarioId], references: [id])
  detalles     DetalleCompra[]
}

model DetalleCompra {
  id             Int      @id @default(autoincrement())
  compraId       Int
  productoId     Int
  cantidad       Int
  precioUnitario Float
  subtotal       Float
  compra         Compra   @relation(fields: [compraId], references: [id])
  producto       Producto @relation(fields: [productoId], references: [id])
}

model MovimientoInventario {
  id          Int      @id @default(autoincrement())
  productoId  Int
  tipo        String   // entrada, salida, ajuste
  cantidad    Int
  referencia  String?
  fecha       DateTime @default(now())
  producto    Producto @relation(fields: [productoId], references: [id])
}

model Empleado {
  id           Int      @id @default(autoincrement())
  nombre       String
  puesto       String
  salario      Float
  telefono     String?
  email        String?
  fechaIngreso DateTime @default(now())
  activo       Boolean  @default(true)
}

model MovimientoContable {
  id          Int      @id @default(autoincrement())
  tipo        String   // ingreso, egreso
  categoria   String   // ventas, compras, nomina, gastos, otros
  monto       Float
  descripcion String
  fecha       DateTime @default(now())
  referencia  String?
}
